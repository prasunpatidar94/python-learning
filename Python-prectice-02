        "## break in loops\n",
        "\n",
        "j = 0\n",
        "while (j<10):\n",
        "  j= j+1\n",
        "  if (j==5):\n",
        "    print(\"break loop for J value is : \",j)\n",
        "    break;\n",
        "  print(\"J is : \",j)\n",
        "\n",
        "print(\"--------------------------------------\")\n",
        "\n",
        "for i in range(10):\n",
        "  if i>5:\n",
        "    print(\"loop is brack for I value is : \",i)\n",
        "    break\n",
        "  print('I is : ',i)"
